# ---------------------------------------------------
# SI-Menu Backend — Environment Configuration Template
# Copy this file to ".env" and fill in real values.
# NEVER commit the actual ".env" file to source control.
# ---------------------------------------------------

# Server
PORT=5000
NODE_ENV=development

# Database (use a dedicated production cluster with IP allow-listing in real deployments)
MONGO_URI=mongodb://127.0.0.1:27017/si-menu

# CORS — comma-separated list of allowed frontend origins (per-environment)
CLIENT_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth — used to sign and verify owner login tokens. MUST be a long, random,
# secret string — generate one with (in a Command Prompt/Terminal):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Never reuse this value across projects, and never commit the real value.
JWT_SECRET=replace-this-with-a-long-random-generated-string
